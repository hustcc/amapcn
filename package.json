{
  "name": "amapcn-monorepo",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build:map": "pnpm --filter amapcn build",
    "build:cn": "pnpm --filter amapcn-registry build",
    "build:site": "pnpm --filter amapcn-site build",
    "dev:site": "pnpm --filter amapcn-site dev",
    "build": "pnpm build:map && pnpm build:cn && pnpm build:site"
  }
}